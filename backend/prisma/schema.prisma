generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id    String @id @default(uuid())
  name  String
  email String @unique
  role  String @default("scout")

  sectionId String?
  section   Section? @relation(fields: [sectionId], references: [id])
}

model Section {
  id   String @id @default(uuid())
  name String @unique

  users User[]
}
