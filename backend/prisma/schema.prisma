generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  role      String   @default("scout")

  birthDate       DateTime?
  identityNumber  String?
  joinDate        DateTime?

  sectionId String?
  section   Section? @relation(fields: [sectionId], references: [id])

  patrolId  String?
  patrol    Patrol? @relation(fields: [patrolId], references: [id])
}

model Section {
  id   String @id @default(uuid())
  name String @unique

  users User[]
}
model Patrol {
  id    String @id @default(uuid())
  name  String @unique

  users User[]
}