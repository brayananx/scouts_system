generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SystemUser {
  id        String   @id @default(uuid())
  name      String
  username  String?  @unique
  password  String
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
}

model User {
  id    String @id @default(uuid())

  name String

  identityNumber String @unique

  birthDate DateTime?

  gender Gender

  religion String?

  nationality String?

  address String?

  phone String

  role String @default("scout")

  joinDate DateTime?

  isInvested Boolean @default(false)

  promiseDate DateTime?

  attendance Attendance[]

  compassLevel Int @default(1)
  logbookLevel Int @default(1)

  progress UserProgress[]

  specialties UserSpecialty[]

  isActive Boolean @default(true)

  inactiveReason String?

  inactiveDate DateTime?

  medicalRecord MedicalRecord?

  sectionId String?
  section Section? @relation(fields: [sectionId], references: [id])

  patrolId String?
  patrol Patrol? @relation(fields: [patrolId], references: [id])
}

enum Gender {
  MALE
  FEMALE
}

model UserProgress {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  type         ProgressType
  level        Int
  obtainedDate DateTime

  @@unique([userId, type, level])
}

enum ProgressType {
  COMPASS
  LOGBOOK
}

model Specialty {
  id       String @id @default(uuid())
  name     String @unique
  imageKey String @unique

  users UserSpecialty[]
}

model UserSpecialty {
  id           String    @id @default(uuid())
  obtainedDate DateTime?

  userId      String
  specialtyId String

  user      User      @relation(fields: [userId], references: [id])
  specialty Specialty @relation(fields: [specialtyId], references: [id])

  @@unique([userId, specialtyId])
}

model Section {
  id   String @id @default(uuid())
  name String @unique

  users User[]
}

model Patrol {
  id   String @id @default(uuid())
  name String @unique

  users User[]
}

model MedicalRecord {
  id                String  @id @default(uuid())
  bloodType         String?
  allergies         String?
  medications       String?
  medicalConditions String?
  emergencyContact  String?
  emergencyPhone    String?
  guardianName      String?
  notes             String?

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])
}

model Activity {
  id          String   @id @default(uuid())
  name        String
  date        DateTime
  description String?

  attendance Attendance[]
}

model Attendance {
  id         String @id @default(uuid())

  activityId String
  userId     String

  activity Activity @relation(fields: [activityId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  present Boolean @default(false)

  @@unique([activityId, userId])
}